# Environment

PORT=3000
JWT_SECRET=replace-with-secure-random-secret
SESSION_COOKIE_NAME=lna_session
SESSION_TTL_SECONDS=604800
ADMIN_EMAILS=admin@example.com
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=25
REDIS_URL=redis://localhost:6379
API_RATE_LIMIT_PREFIX=rl:api
AUTH_RATE_LIMIT_PREFIX=rl:auth

# AI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/live_negotiation_ai?schema=public

# Admin bootstrap command (optional)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-this-password
SEED_ADMIN_NAME=Platform Admin
